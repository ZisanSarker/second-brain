# ==============================================================================
# AI SECOND BRAIN - GLOBAL ENVIRONMENT VARIABLE TEMPLATE
# Copy to .env in respective directories or root during deployment
# ==============================================================================

# ------------------------------------------------------------------------------
# DOCKER COMPOSE SERVICE CREDENTIALS
# ------------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=secondbrain
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ------------------------------------------------------------------------------
# FRONTEND CONFIGURATION (apps/web)
# ------------------------------------------------------------------------------
PORT_WEB=3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# ------------------------------------------------------------------------------
# BACKEND GATEWAY CONFIGURATION (apps/api)
# ------------------------------------------------------------------------------
PORT_API=3001
NODE_ENV=development
# WARNING: In production, generate strong random secrets (openssl rand -hex 64)
JWT_SECRET=super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=1d
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Relational Database connection
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/secondbrain?schema=public

# Redis Connection (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# FastAPI AI Service connection
AI_SERVICE_URL=http://localhost:8000

# MinIO Object Storage Setup
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=documents

# ------------------------------------------------------------------------------
# AI PYTHON MICROSERVICE CONFIGURATION (apps/ai)
# ------------------------------------------------------------------------------
PORT=8000
HOST=0.0.0.0

# OpenRouter (unified LLM gateway — supports GPT, Claude, Gemini, Llama, etc.)
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemma-4-31b-it:free

# Email (SMTP via Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
EMAIL_FROM="Second Brain <your-email@gmail.com>"

# Vector Database (Qdrant)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
