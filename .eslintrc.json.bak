{
  "root": true,
  "ignorePatterns": [
    "apps/**",
    "packages/**",
    "node_modules/**",
    "dist/**",
    ".next/**",
    "out/**"
  ],
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "env": {
    "node": true,
    "es2022": true
  }
}
