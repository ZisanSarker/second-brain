{
  "name": "second-brain-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "AI Second Brain Workspace Monorepo",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{js,ts,tsx,json,md,yml,yaml,css}\"",
    "check-types": "turbo run check-types",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "globals": "^17.7.0",
    "husky": "^9.0.11",
    "lint-staged": "^17.0.8",
    "prettier": "^3.3.2",
    "turbo": "^2.0.4",
    "typescript": "^6.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "pnpm": {
    "overrides": {
      "multer": ">=2.0.3"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "@apollo/server": "^5"
      }
    }
  }
}
